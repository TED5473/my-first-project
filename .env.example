# --- IL CarLens environment ---

# Prisma — PostgreSQL (Supabase / Neon / Railway / local docker).
# DATABASE_URL goes through the pooler (pgbouncer); DIRECT_URL is used by
# Prisma Migrate and must bypass the pooler.
#
# Local docker-compose example:
#   docker compose up -d
#   DATABASE_URL="postgresql://ilcl:ilcl@localhost:5432/ilcl?schema=public"
#   DIRECT_URL="postgresql://ilcl:ilcl@localhost:5432/ilcl?schema=public"
#
# Supabase example (from Project Settings → Database):
#   DATABASE_URL="postgresql://postgres.xxxx:PW@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#   DIRECT_URL="postgresql://postgres.xxxx:PW@aws-0-REGION.pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://ilcl:ilcl@localhost:5432/ilcl?schema=public"
DIRECT_URL="postgresql://ilcl:ilcl@localhost:5432/ilcl?schema=public"

# Authentication (choose one). For OSS/dev, leave empty to allow public read.
NEXTAUTH_SECRET=""
ADMIN_API_TOKEN="change-me-admin-token"

# Cron protection (Vercel Cron injects this header automatically)
CRON_SECRET="change-me-cron-secret"

# Scraping
IVIA_REPORTS_INDEX_URL="https://www.ivia.co.il"
PLAYWRIGHT_HEADLESS="true"

# Public app URL
NEXT_PUBLIC_APP_NAME="IL CarLens"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
